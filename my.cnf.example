#
# MariaDB configuration for aligned TPC-C benchmark across three engines:
#   InnoDB, MyRocks (RocksDB), TideSQL (TidesDB)
#
# This config disables full per-commit durability ACROSS ALL THREE ENGINES
# so we measure storage-engine throughput and latency, NOT fsync latency
# of the underlying NVMe. Aligning durability OFF is honest because doing
# it for one engine without the others would skew the result.
#
# Compression is OFF on all three engines. This was a deliberate choice:
# enabling InnoDB page compression in MariaDB requires per-table DDL
# (PAGE_COMPRESSED=1), which HammerDB's TPC-C schema builder does not
# emit. Rather than alter the schema for one engine only (which itself
# would be a methodology asymmetry), we run all three uncompressed.
# Disk footprint will differ across engines but throughput/latency
# numbers reflect raw engine behavior with no compression CPU overhead.
#
# Production deployments should re-enable:
#   innodb_flush_log_at_trx_commit     = 1
#   innodb_doublewrite                 = ON
#   rocksdb_flush_log_at_trx_commit    = 1
#   tidesdb_unified_memtable_sync_mode = FULL
#
# Sized for the following hardware:
#   AMD Ryzen Threadripper 2950X  - 16 cores / 32 threads @ 3.5 GHz
#   128 GB DDR4
#   Samsung MZVLB512HAJQ-00000 NVMe (PM981a-class)
#   Ubuntu 22.04 x86_64, XFS on raw NVMe (discard, inode64, nodiratime,
#       noatime, logbsize=256k, logbufs=8)
#
# Sources for the per-engine settings below
#  * MyRocks: Facebook's official my.cnf-tuning wiki (Yoshinori Matsunobu)
#      https://github.com/facebook/mysql-5.6/wiki/my.cnf-tuning
#
#  * InnoDB: MariaDB.org performance evaluation methodology and MariaDB
#    Documentation system-variables reference.
#      https://mariadb.org/performance-evaluation-of-mariadb-10-1-...
#      https://mariadb.com/docs/server/server-usage/storage-engines/innodb/innodb-system-variables
#
#  * TidesDB / TideSQL: official reference docs
#      https://tidesdb.com/reference/tidesql/
#
# Alignment principle
#
# HELD ALIGNED across engines:
#   - Primary explicit cache budget         : 32 GB
#       innodb_buffer_pool_size              = 32G
#       rocksdb_block_cache_size             = 32G
#       tidesdb_block_cache_size             = 32G
#     (sized conservatively: even if all three caches were touched
#      concurrently they fit in 128 GB with headroom for memtables,
#      connections, OS page cache, and HammerDB driver memory)
#
#   - Write-side memory budget               : 1 GB
#       innodb_log_file_size                 = 1G
#       rocksdb write_buffer_size            = 256M * max_write_buffer_number=4 = 1G
#       tidesdb_unified_memtable_write_buffer_size = 1G
#         (unified = ONE shared memtable across ALL CFs, so 1G is
#         comparable to MyRocks's per-CF 1G total memtable memory;
#         the comparison axis is "how much data can sit in memory
#         before flush")
#
#   - Background helper threads (8 per engine, 25% of 32-thread CPU,
#     leaving 24 threads for HammerDB virtual users + foreground work)
#       InnoDB  : 2 purge + 2 read_io + 4 write_io           = 8
#       RocksDB : rocksdb_max_background_jobs                = 8
#       TidesDB : 4 flush + 4 compaction                     = 8
#
#   - Durability                             = OFF (benchmark mode)
#       innodb_flush_log_at_trx_commit       = 0  (flush every ~1s)
#       innodb_doublewrite                   = OFF
#       rocksdb_flush_log_at_trx_commit      = 0  (flush every ~1s)
#       tidesdb_unified_memtable_sync_mode   = NONE
#
#   - Compression                            = OFF (all engines)
#       (no innodb_compression_default, no compression_per_level in
#       MyRocks CF options, tidesdb_default_compression = NONE)
#
#   - Transaction isolation                  = READ-COMMITTED
#   - Binlog                                 = OFF
#   - performance_schema                     = OFF (instrumentation
#       overhead is asymmetric across engines)
#
# Not held aligned (engine-native architectural differences):
#   - I/O method: InnoDB uses O_DIRECT (bypasses OS cache); MyRocks and
#     TidesDB use buffered I/O (their native design - SST data benefits
#     from OS page cache).
#

[mysqld]
basedir   = /data/mariadb
datadir   = /data/mariadb/data
port      = 3306
socket    = /tmp/mariadb.sock
user      = root
pid-file  = /data/mariadb/data/mariadb.pid
log-error = /data/mariadb/data/mariadb.err

# All plugins loaded in a single directive (semicolon-separated).
# A second plugin_load_add line would override this one, not append to it.
plugin_load_add = ha_rocksdb.so;ha_tidesdb.so

plugin_maturity = gamma

# Networking and connections
bind-address      = 127.0.0.1
max_connections   = 4096
thread_cache_size = 256
table_open_cache  = 16384

# Open-file limit at the mysqld level (must also be raised at OS level
# via /etc/security/limits.conf or systemd LimitNOFILE - see preflight notes)
open_files_limit  = 1048576

# Replication / binlog
skip-log-bin

# Performance schema OFF - its instrumentation cost is asymmetric across
# engines (InnoDB is more thoroughly instrumented than MyRocks/TidesDB),
# which would skew the comparison.
performance_schema = OFF

# Default engine and isolation
default_storage_engine     = InnoDB

# REQUIRED when MyRocks is loaded: MyRocks doesn't support internal temp
# tables, so the server must fall back to MyISAM for them.
default_tmp_storage_engine = MyISAM

# Facebook's explicit recommendation for MyRocks; supported by InnoDB and TidesDB.
transaction_isolation      = READ-COMMITTED

# Character set
character-set-server = utf8mb4
collation-server     = utf8mb4_general_ci

# Slow query log
slow_query_log      = ON
slow_query_log_file = /data/mariadb/data/slow.log
long_query_time     = 2

# ============================================================================
# InnoDB
# ============================================================================

# ALIGNED cache: 32 GB
innodb_buffer_pool_size        = 32G

# ALIGNED write-side memory: 1 GB
innodb_log_file_size           = 1G
innodb_log_buffer_size         = 64M

# === BENCHMARKING DURABILITY ===
innodb_flush_log_at_trx_commit = 0           # flush + sync log every ~1s (not per commit)
innodb_doublewrite             = OFF         # disable double-write buffer
innodb_flush_method            = O_DIRECT_NO_FSYNC  # skip per-write fsync (faster than O_DIRECT
                                                    # when innodb_flush_log_at_trx_commit != 1)

innodb_file_per_table          = ON

# I/O concurrency - ALIGNED 8 background threads (2 purge + 2 read_io + 4 write_io).
innodb_read_io_threads         = 2
innodb_write_io_threads        = 4
innodb_purge_threads           = 2
innodb_thread_concurrency      = 0           # unlimited foreground

# NVMe I/O capacity
innodb_io_capacity             = 10000
innodb_io_capacity_max         = 20000

innodb_use_native_aio          = 1
innodb_adaptive_flushing       = 1

# Larger sort/temp budgets for HammerDB build phase
tmp_table_size                 = 128M
max_heap_table_size            = 128M

# ============================================================================
# MyRocks (RocksDB)
# ============================================================================

# Avoid table-cache mutex on every SST file access (FB critical recommendation).
rocksdb_max_open_files            = -1

# ALIGNED cache: 32 GB
rocksdb_block_cache_size          = 32G

# Larger block size (FB recommends 16384)
rocksdb_block_size                = 16384

# Shard cache mutexes more finely (FB recommendation)
rocksdb_table_cache_numshardbits  = 6

# 0 = WAL flushed every ~1 second (background thread), not per commit.
# Roughly equivalent to innodb_flush_log_at_trx_commit=0.
rocksdb_flush_log_at_trx_commit   = 0

# WAL crash safety mode (PointInTimeRecovery - tolerates WAL tail
# corruption after benchmark-driven SIGKILLs)
rocksdb_wal_recovery_mode         = 2
rocksdb_max_total_wal_size        = 4G

# ALIGNED background jobs: 8.
rocksdb_max_background_jobs       = 8
rocksdb_max_subcompactions        = 2

# Rate limiter - smooths compaction bursts, 0 lets rocks decide
rocksdb_rate_limiter_bytes_per_sec = 0

# Sync intervals (FB recommended 4M; with durability off these are advisory)
rocksdb_bytes_per_sync             = 4M
rocksdb_wal_bytes_per_sync         = 4M

# Direct I/O OFF - MyRocks's native design uses OS page cache for SSTs.
rocksdb_use_direct_reads                       = 0
rocksdb_use_direct_io_for_flush_and_compaction = 0

rocksdb_bulk_load                  = 0
rocksdb_bulk_load_allow_unsorted   = 0

# Column-family options. Compression keys (compression_per_level,
# bottommost_compression, compression_opts) have been REMOVED so MyRocks
# writes uncompressed SSTs, matching InnoDB and TidesDB.
# Memtable budget: write_buffer_size=256m * max_write_buffer_number=4 = 1G,
# aligned with the 1 GB write-side budget on the other engines.
rocksdb_default_cf_options = "write_buffer_size=256m;target_file_size_base=64m;max_bytes_for_level_base=1g;level0_file_num_compaction_trigger=4;level0_slowdown_writes_trigger=10;level0_stop_writes_trigger=15;max_write_buffer_number=4;block_based_table_factory={cache_index_and_filter_blocks=1;filter_policy=bloomfilter:10:false;whole_key_filtering=1};level_compaction_dynamic_level_bytes=true;optimize_filters_for_hits=true;compaction_pri=kMinOverlappingRatio"

# Tombstone-triggered compaction (FB example). Helps TPC-C delivery cycle.
rocksdb_compaction_sequential_deletes_count_sd = 1
rocksdb_compaction_sequential_deletes          = 199999
rocksdb_compaction_sequential_deletes_window   = 200000

# ============================================================================
# TidesDB (TideSQL)
# ============================================================================

# Let TidesDB manage its own memory ceiling (it respects the explicit
# block_cache_size and memtable_write_buffer_size below).
tidesdb_max_memory_usage = 0

# ALIGNED cache: 32 GB
tidesdb_block_cache_size                       = 32G

# Unified memtable is one shared WAL + memtable across all column families.
# ALIGNED write-side memory: 1 GB
tidesdb_unified_memtable                       = ON
tidesdb_unified_memtable_write_buffer_size     = 1G

# NONE = no fsync on commit. Roughly equivalent to MyRocks
# rocksdb_flush_log_at_trx_commit=0 and InnoDB innodb_flush_log_at_trx_commit=0.
tidesdb_unified_memtable_sync_mode             = NONE

# ALIGNED background threads
tidesdb_flush_threads                          = 4
tidesdb_compaction_threads                     = 4

# File-handle LRU cap. With 1000 warehouses + many CFs (one per index),
# raise generously.
tidesdb_max_open_sstables                      = 4096

tidesdb_default_sync_mode    = NONE
tidesdb_default_compression  = NONE
tidesdb_log_level            = NONE

# Align L0 stall threshold with RocksDB level0_stop_writes_trigger=15
# and L1 trigger with level0_file_num_compaction_trigger=4.
tidesdb_default_l0_queue_stall_threshold = 24
tidesdb_default_l1_file_count_trigger    = 4

# Safe for TPC-C - every INSERT PK is application-monotonic (d_next_o_id,
# ol_number, AUTO_INCREMENT h_id) and the HammerDB schema has no UNIQUE
# secondary indexes, so the dup-check path has nothing to enforce.
tidesdb_skip_unique_check = ON

# Match the server-wide transaction_isolation set above.
tidesdb_default_isolation_level = READ_COMMITTED

# Tighter bloom FPR (0.1% vs default 1%) cuts false-positive SSTable
# seeks ~10x. TPC-C is point-lookup heavy (CUSTOMER, STOCK, ITEM,
# WAREHOUSE by PK).
tidesdb_default_bloom_fpr = 10

# 1024 keeps the full CUSTOMER row inline in klog (c_data 500B + name
# and address fields ~200B crosses the default 512), removing one vlog
# hop per Payment.
tidesdb_default_klog_value_threshold = 1024

tidesdb_lock_wait_timeout_ms = 240000
tidesdb_backpressure_wait_timeout_ms = 600000  

# Tombstone-density compaction trigger - ALIGNED with MyRocks's
# rocksdb_compaction_sequential_deletes_* settings (above), which trigger
# compaction when an SSTable accumulates a window of sequential deletes.
# This is the same class of optimization: notice tombstone buildup, escalate
# compaction to reclaim space and reduce read overhead. Without this, TidesDB
# is at a disadvantage to MyRocks specifically on Delivery transactions which
# DELETE from new_order.
#
# Secondary-index single-delete is automatic in TidesDB (no config needed)
# and covers the secondary-index tombstone path for all DELETEs.
#
# Primary-CF single-delete (tidesdb_single_delete_primary) is intentionally
# left OFF - it can cause correctness issues
# when the workload contains UPDATE on non-PK columns or REPLACE INTO patterns.
# TPC-C's Payment transaction UPDATEs balances, and New Order can hit IODKU
# paths, so enabling primary-CF SD is unsafe here.
tidesdb_default_tombstone_density_trigger      = 5000   # 50% (parts per 10000)
tidesdb_default_tombstone_density_min_entries  = 2048

[client]
port                  = 3306
socket                = /tmp/mariadb.sock
default-character-set = utf8mb4

[mysqldump]
quick
max_allowed_packet = 64M

[mariadb-backup]
# defaults are fine

# jemalloc via mysqld_safe. NOTE: on Ubuntu 22.04 the default systemd unit
# (mariadb.service) does NOT invoke mysqld_safe and therefore ignores this
# section. To actually load jemalloc with systemd, add a drop-in:
#   /etc/systemd/system/mariadb.service.d/jemalloc.conf
#   [Service]
#   Environment="LD_PRELOAD=/lib/x86_64-linux-gnu/libjemalloc.so.2"
# Then `systemctl daemon-reload && systemctl restart mariadb` and verify
# with: pmap $(pidof mariadbd) | grep jemalloc
[mysqld_safe]
malloc-lib=/lib/x86_64-linux-gnu/libjemalloc.so.2
