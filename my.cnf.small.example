#
# MariaDB configuration for aligned TPC-C benchmark across three engines:
#   InnoDB, MyRocks (RocksDB), TidesDB (TideSQL)
#
# SMALL-ENV VARIANT
#
# Sized for consumer hardware:
#   ~4-8 core CPU (i5/i7/Ryzen 5)
#   8 GB RAM
#   Consumer SSD (SATA or modest NVMe)
#   1-10 GB target schema (40 TPC-C warehouses = ~4 GB)
#
# Matches the workload pattern of:
#   ./hammerdb_runner.sh -b tpcc \
#       --warehouses 40 --tpcc-vu 8 --tpcc-build-vu 8 \
#       --rampup 1 --duration 2 --settle 5 ...
#
# Memory budget (8 GB total)
#   ~2 GB     OS + filesystem caches + HammerDB process + mariadbd overhead
#   ~1 GB     primary engine cache    (aligned across all 3 engines)
#   ~256 MB   write-side memtables / log buffers
#   ~5 GB     HEADROOM for OS page cache, transaction memory, compaction scratch
#
# At 40 warehouses (~4 GB on disk), 1 GB cache means ~25% of working set fits
# in primary cache - same "moderate-IO" character as the 32GB/100GB big-box
# config. If you have 16 GB RAM, double the cache values. If you have 4 GB,
# halve them (and expect more I/O-bound results).
#
# Same as the big-box config: aligned-off across all three engines so we
# measure storage-engine performance, not fsync latency.
# Production deployments should re-enable:
#   innodb_flush_log_at_trx_commit     = 1
#   innodb_doublewrite                 = ON
#   rocksdb_flush_log_at_trx_commit    = 1
#   tidesdb_unified_memtable_sync_mode = FULL
#
# Alignment held across engines
#   - Primary cache budget               : 1 GB per engine
#   - Write-side memory                  : ~128 MB per engine
#   - Background helper threads          : 4 per engine (2+2)
#   - Durability                         : OFF
#   - Transaction isolation              : READ-COMMITTED
#   - Binlog                             : OFF
#   - Tombstone-triggered compaction     : ON for both LSM engines
#

[mysqld]
basedir = /media/agpmastersystem/c794105c-0cd9-4be9-8369-ee6d6e707d68/home/bench/mariadb
datadir = /media/agpmastersystem/c794105c-0cd9-4be9-8369-ee6d6e707d68/home/bench/mariadb/data
port    = 3306
socket  = /tmp/mariadb.sock
user    = agpmastersystem
pid-file = /media/agpmastersystem/c794105c-0cd9-4be9-8369-ee6d6e707d68/home/bench/mariadb/data/mariadb.pid
log-error = /media/agpmastersystem/c794105c-0cd9-4be9-8369-ee6d6e707d68/home/bench/mariadb/data/mariadb.err

# Networking and connections
bind-address      = 127.0.0.1
max_connections   = 256              # headroom for 8 VUs + monitor
thread_cache_size = 32
table_open_cache  = 2048
open_files_limit  = 65536            # still raise this for rocksdb_max_open_files=-1

# Replication / binlog
skip-log-bin

# Default engine and isolation
default_storage_engine     = InnoDB
default_tmp_storage_engine = MyISAM   # required when MyRocks is loaded
transaction_isolation      = READ-COMMITTED

# Character set
character-set-server = utf8mb4
collation-server     = utf8mb4_general_ci

# Slow query log
slow_query_log      = ON
slow_query_log_file = /media/agpmastersystem/c794105c-0cd9-4be9-8369-ee6d6e707d68/home/bench/mariadb/data/slow.log
long_query_time     = 2

# InnoDB

innodb_buffer_pool_size        = 1G        # ALIGNED at 1G
# innodb_buffer_pool_instances   = 1         # not avil anymore mariadb > 10 

innodb_log_file_size           = 128M      # ~12% of buffer pool

# innodb_log_files_in_group not valid MariaDB > 10
# innodb_log_files_in_group      = 2

innodb_log_buffer_size         = 16M

# match tidesdb and rocksdb compression 1:1
innodb_compression_default = ON
innodb_compression_algorithm = lz4

# === BENCHMARKING DURABILITY OFF ===
innodb_flush_log_at_trx_commit = 0
innodb_doublewrite             = OFF
innodb_flush_method            = O_DIRECT_NO_FSYNC

innodb_file_per_table          = ON

# I/O concurrency - 2+2 = 4 background threads, matches consumer CPU
innodb_read_io_threads         = 2
innodb_write_io_threads        = 2
innodb_purge_threads           = 2
innodb_thread_concurrency      = 0

# Consumer SSD I/O capacity (SATA SSD: ~500-1000 IOPS sustained random write;
# consumer NVMe: ~3000-5000)
innodb_io_capacity             = 1000
innodb_io_capacity_max         = 4000

innodb_use_native_aio          = 1
innodb_adaptive_flushing       = 1

tmp_table_size                 = 32M
max_heap_table_size            = 32M

# MyRocks (RocksDB)

plugin_load_add = ha_rocksdb.so

rocksdb_max_open_files            = -1

# Cache - ALIGNED at 1G
rocksdb_block_cache_size          = 1G
rocksdb_block_size                = 16384
rocksdb_table_cache_numshardbits  = 6

# Durability OFF
rocksdb_flush_log_at_trx_commit   = 0

rocksdb_wal_recovery_mode         = 2
rocksdb_max_total_wal_size        = 1G     # scaled down from 4G

# Background jobs - 4 for consumer CPU
rocksdb_max_background_jobs       = 4
rocksdb_max_subcompactions        = 2

# Rate limiter - 100 MB/s is appropriate for consumer SSDs
rocksdb_rate_limiter_bytes_per_sec = 100M

rocksdb_bytes_per_sync             = 4M
rocksdb_wal_bytes_per_sync         = 4M

# Direct I/O OFF (use OS page cache - MyRocks native design)
rocksdb_use_direct_reads                       = 0
rocksdb_use_direct_io_for_flush_and_compaction = 0

# Bulk-load - toggled by the benchmark script around schema build
rocksdb_bulk_load                  = 0
rocksdb_bulk_load_allow_unsorted   = 0

# Column-family options - FB-recommended, scaled down for small env.
# write_buffer_size=64m * max_write_buffer_number=2 = ~128m memtable footprint
rocksdb_default_cf_options = "write_buffer_size=64m;target_file_size_base=32m;max_bytes_for_level_base=256m;level0_file_num_compaction_trigger=4;level0_slowdown_writes_trigger=10;level0_stop_writes_trigger=15;max_write_buffer_number=2;compression_per_level=kLZ4Compression;bottommost_compression=kZSTD;compression_opts=-14:6:0;block_based_table_factory={cache_index_and_filter_blocks=1;filter_policy=bloomfilter:10:false;whole_key_filtering=1};level_compaction_dynamic_level_bytes=true;optimize_filters_for_hits=true;compaction_pri=kMinOverlappingRatio"

# Tombstone-triggered compaction (FB example).
rocksdb_compaction_sequential_deletes_count_sd = 1
rocksdb_compaction_sequential_deletes          = 199999
rocksdb_compaction_sequential_deletes_window   = 200000


# TidesDB (TideSQL)

plugin_maturity = gamma
plugin_load_add = ha_tidesdb.so

# allow tidesdb to use most memory
tidesdb_max_memory_usage = 0

# Cache - ALIGNED at 1G
tidesdb_block_cache_size                       = 1G

# Unified memtable - shared buffer for all CFs
tidesdb_unified_memtable                       = ON
tidesdb_unified_memtable_write_buffer_size     = 128M   # scaled down from 512M

# Durability OFF
tidesdb_unified_memtable_sync_mode             = NONE

# Background threads - 2 + 2 = 4 matches MyRocks max_background_jobs=4 and InnoDB (2+2)
tidesdb_flush_threads                          = 2
tidesdb_compaction_threads                     = 2

# File-handle LRU cap - scaled down for smaller schema
tidesdb_max_open_sstables                      = 1024

# match rocksdb bulk load optimization
tidesdb_skip_unique_check = ON

# match mariadb configured default in this file, you need to set both
tidesdb_default_isolation_level = READ_COMMITTED

# irrelevant in unified mode
tidesdb_default_write_buffer_size              = 128M

tidesdb_default_sync_mode                      = NONE
tidesdb_default_compression                    = LZ4
tidesdb_log_level                              = NONE
tidesdb_default_l0_queue_stall_threshold       = 20
tidesdb_default_l1_file_count_trigger          = 4

# Tombstone-density trigger - ALIGNED with MyRocks sequential_deletes settings.
# Primary-CF single-delete (tidesdb_single_delete_primary) intentionally left
# OFF - unsafe for TPC-C because Payment UPDATEs non-PK columns. Secondary-index
# single-delete is automatic, no config needed.
tidesdb_default_tombstone_density_trigger      = 5000
tidesdb_default_tombstone_density_min_entries  = 2048

# Optional explicit memory cap. With tidesdb_max_memory_usage=0, TidesDB picks
# 50% of system RAM (~4G on an 8GB box) automatically. To leave more for OS:
# tidesdb_max_memory_usage = 3G

[client]
port                  = 3306
socket                = /tmp/mariadb.sock
default-character-set = utf8mb4

[mysqldump]
quick
max_allowed_packet = 64M

[mariadb-backup]
# defaults are fine

# if you want jemalloc or another
[mysqld_safe]
malloc-lib=/lib/x86_64-linux-gnu/libjemalloc.so.2
